{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@data/*":       ["src/data/*"],
      "@layouts/*":    ["src/layouts/*"],
      "@styles/*":     ["src/styles/*"]
    }
  }
}
