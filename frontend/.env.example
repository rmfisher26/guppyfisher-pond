# .env.example
# Copy to .env and fill in values for your environment.
# Astro reads .env automatically — never commit .env to git.

# ── Backend URL ───────────────────────────────────────────────────────────────
# URL of the FastAPI guppy-backend server.
# Used by src/pages/api/compile.ts in SSR mode.
# Defaults to localhost:8000 if not set.
BACKEND_URL=http://localhost:8000

# ── Site URL ──────────────────────────────────────────────────────────────────
# Set when deploying — used for OG meta tags and sitemaps.
# Also set `site` in astro.config.mjs.
# SITE_URL=https://guppyfisher.dev

# ── Feature flags (optional) ──────────────────────────────────────────────────
# Set to 'true' to show a "Live compilation" badge in the UI
# when the real backend is connected.
 PUBLIC_LIVE_BACKEND=false
